# ─────────────────────────────────────────────────────────────────────────────
# TradeSphere — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env.
# ─────────────────────────────────────────────────────────────────────────────

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=tradesphere
POSTGRES_PASSWORD=tradesphere

REDIS_HOST=localhost
REDIS_PORT=6379

KAFKA_SERVERS=localhost:9092

MONGODB_URI=mongodb://tradesphere:tradesphere@localhost:27017/tradesphere_notifications?authSource=admin

# Generate: openssl rand -base64 32
# Must be the SAME value across all 7 services
JWT_SECRET=REPLACE_WITH_256_BIT_RANDOM_SECRET

# Finnhub — free tier: https://finnhub.io
FINNHUB_API_KEY=your_finnhub_api_key_here

# Twelve Data — free tier: https://twelvedata.com
TWELVEDATA_API_KEY=your_twelvedata_api_key_here
